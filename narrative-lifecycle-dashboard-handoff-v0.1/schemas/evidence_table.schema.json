{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "title": "EvidenceTable",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": true,
    "required": [
      "evidence_id",
      "topic_id",
      "event_date",
      "available_at",
      "event_title",
      "event_summary",
      "event_type",
      "source_name",
      "source_url",
      "source_type",
      "evidence_strength",
      "affected_layer",
      "stage_effect",
      "parent_or_branch",
      "branch_coverage_score",
      "interpretation",
      "limitation",
      "positive_or_negative",
      "confidence"
    ],
    "properties": {
      "evidence_id": {
        "type": "string",
        "minLength": 1
      },
      "topic_id": {
        "type": "string",
        "minLength": 1
      },
      "branch_id": {
        "type": [
          "string",
          "null"
        ]
      },
      "event_date": {
        "type": "string",
        "format": "date"
      },
      "available_at": {
        "type": "string",
        "format": "date"
      },
      "event_title": {
        "type": "string",
        "minLength": 1
      },
      "event_summary": {
        "type": "string",
        "minLength": 1
      },
      "event_type": {
        "type": "string",
        "minLength": 1
      },
      "source_name": {
        "type": "string",
        "minLength": 1
      },
      "source_url": {
        "type": "string",
        "format": "uri"
      },
      "source_type": {
        "type": "string",
        "minLength": 1
      },
      "evidence_strength": {
        "type": "string",
        "enum": [
          "E0",
          "E1",
          "E2",
          "E3",
          "E4"
        ]
      },
      "affected_layer": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "enum": [
            "perception",
            "capital",
            "pricing",
            "reality",
            "feedback",
            "friction"
          ]
        }
      },
      "stage_effect": {
        "type": "string",
        "minLength": 1
      },
      "parent_or_branch": {
        "type": "string",
        "enum": [
          "parent",
          "branch",
          "asset",
          "unknown"
        ]
      },
      "branch_coverage_score": {
        "type": "number",
        "minimum": 0,
        "maximum": 100
      },
      "interpretation": {
        "type": "string",
        "minLength": 1
      },
      "limitation": {
        "type": "string",
        "minLength": 1
      },
      "positive_or_negative": {
        "type": "string",
        "enum": [
          "positive",
          "negative",
          "neutral"
        ]
      },
      "confidence": {
        "type": "number",
        "minimum": 0,
        "maximum": 100
      }
    },
    "allOf": [
      {
        "if": {
          "properties": {
            "parent_or_branch": {
              "const": "branch"
            }
          },
          "required": [
            "parent_or_branch"
          ]
        },
        "then": {
          "required": [
            "branch_id"
          ]
        }
      }
    ]
  }
}
