{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "WeeklyBrief",
  "required": [
    "report_id",
    "artifact_type",
    "schema_version",
    "producer_version",
    "rule_version",
    "run_id",
    "generated_at",
    "source_artifacts",
    "executive_summary",
    "stage_snapshot",
    "stage_change_summary",
    "stage_changes",
    "strongest_evidence",
    "why_not_higher",
    "early_radar_candidates",
    "guardrail_check",
    "next_operator_actions",
    "artifact_index"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "pattern": "^weekly_brief_run_[0-9]{8}T[0-9]{9}_[a-f0-9]{6}$"
    },
    "artifact_type": { "const": "weekly_brief" },
    "schema_version": { "const": "1.0.0" },
    "producer_version": { "const": "0.4.0" },
    "rule_version": { "type": "string" },
    "run_id": {
      "type": "string",
      "pattern": "^run_[0-9]{8}T[0-9]{9}_[a-f0-9]{6}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "executive_summary": {
      "type": "object",
      "required": [
        "dashboard_card_count",
        "score_count",
        "golden_case_passed",
        "golden_case_total",
        "early_radar_candidate_count",
        "system_status"
      ],
      "properties": {
        "dashboard_card_count": {
          "type": "integer",
          "minimum": 0
        },
        "score_count": {
          "type": "integer",
          "minimum": 0
        },
        "golden_case_passed": {
          "type": "integer",
          "minimum": 0
        },
        "golden_case_total": {
          "type": "integer",
          "minimum": 0
        },
        "early_radar_candidate_count": {
          "type": "integer",
          "minimum": 0
        },
        "system_status": {
          "type": "string",
          "enum": [
            "ok",
            "review_required"
          ]
        },
        "rule_version": {
          "type": "string"
        }
      }
    },
    "stage_snapshot": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "topic_id",
          "topic_name",
          "current_stage",
          "parent_narrative",
          "strongest_branch",
          "weakest_layer",
          "data_confidence"
        ],
        "properties": {
          "topic_id": {
            "type": "string"
          },
          "topic_name": {
            "type": "string"
          },
          "current_stage": {
            "type": "string"
          },
          "parent_narrative": {
            "type": "string"
          },
          "strongest_branch": {
            "type": "string"
          },
          "weakest_layer": {
            "type": "string"
          },
          "data_confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          }
        }
      }
    },
    "stage_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "topic_id",
          "topic_name",
          "previous_stage",
          "current_stage",
          "change_type",
          "detected_changes",
          "new_evidence_ids",
          "removed_evidence_ids",
          "change_reason",
          "priority",
          "research_only_action",
          "branch_id",
          "reactivation_record_id"
        ],
        "properties": {
          "topic_id": {
            "type": "string"
          },
          "topic_name": { "type": "string" },
          "previous_stage": {
            "type": [
              "string",
              "null"
            ]
          },
          "current_stage": {
            "type": "string"
          },
          "change_type": {
            "type": "string"
          },
          "detected_changes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "new_evidence_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "removed_evidence_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "change_reason": {
            "type": "string"
          },
          "priority": { "enum": ["low", "medium", "high"] },
          "research_only_action": { "enum": ["observe", "track", "validate", "review", "monitor", "compare", "flag_risk", "request_more_evidence"] },
          "branch_id": { "type": ["string", "null"] },
          "reactivation_record_id": { "type": ["string", "null"] }
        }
      }
    },
    "stage_change_summary": {
      "type": "object",
      "required": ["previous_snapshot_id", "current_snapshot_id", "upgrade_count", "downgrade_count", "evidence_added_count", "branch_mutation_candidate_count", "guardrail_regression_count"],
      "properties": {
        "previous_snapshot_id": { "type": ["string", "null"] },
        "current_snapshot_id": { "type": "string" },
        "upgrade_count": { "type": "integer", "minimum": 0 },
        "downgrade_count": { "type": "integer", "minimum": 0 },
        "evidence_added_count": { "type": "integer", "minimum": 0 },
        "branch_mutation_candidate_count": { "type": "integer", "minimum": 0 },
        "guardrail_regression_count": { "type": "integer", "minimum": 0 }
      }
    },
    "strongest_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "evidence_id",
          "evidence_strength",
          "affected_layer",
          "topic",
          "interpretation"
        ],
        "properties": {
          "evidence_id": {
            "type": "string"
          },
          "evidence_strength": {
            "type": "string"
          },
          "affected_layer": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "topic": {
            "type": "string"
          },
          "interpretation": {
            "type": "string"
          }
        }
      }
    },
    "why_not_higher": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "topic_id",
          "topic_name",
          "current_stage",
          "why_not_higher_stage",
          "evidence_ids"
        ],
        "properties": {
          "topic_id": {
            "type": "string"
          },
          "topic_name": {
            "type": "string"
          },
          "current_stage": {
            "type": "string"
          },
          "why_not_higher_stage": {
            "type": "string",
            "minLength": 1
          },
          "evidence_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "early_radar_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "candidate_id",
          "candidate_topic",
          "reason",
          "reactivation_record_id",
          "evidence_ids",
          "research_only_action"
        ],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "candidate_topic": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "reactivation_record_id": {
            "type": "string",
            "minLength": 1
          },
          "evidence_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "research_only_action": {
            "type": "string"
          }
        }
      }
    },
    "guardrail_check": {
      "type": "object",
      "required": [
        "no_trading_advice",
        "research_only_actions",
        "parent_branch_separation_preserved",
        "evidence_ids_visible",
        "why_not_higher_present",
        "data_confidence_present"
      ],
      "properties": {
        "no_trading_advice": {
          "type": "boolean"
        },
        "research_only_actions": {
          "type": "boolean"
        },
        "parent_branch_separation_preserved": {
          "type": "boolean"
        },
        "evidence_ids_visible": {
          "type": "boolean"
        },
        "why_not_higher_present": {
          "type": "boolean"
        },
        "data_confidence_present": {
          "type": "boolean"
        }
      }
    },
    "next_operator_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "action",
          "reason",
          "evidence_ids"
        ],
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "observe",
              "track",
              "validate",
              "review",
              "monitor",
              "compare",
              "flag_risk",
              "request_more_evidence"
            ]
          },
          "topic_id": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "evidence_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "artifact_index": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
