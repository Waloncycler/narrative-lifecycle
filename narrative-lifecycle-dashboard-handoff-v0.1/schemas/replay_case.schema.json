{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "title": "ReplayCase",
  "additionalProperties": true,
  "required": [
    "case_id",
    "topic_id",
    "topic_name",
    "parent_narrative",
    "scenario_type",
    "requested_stage",
    "data_confidence",
    "slices",
    "evidence",
    "outcome",
    "calibration_note"
  ],
  "properties": {
    "case_id": { "type": "string", "minLength": 1 },
    "topic_id": { "type": "string", "minLength": 1 },
    "topic_name": { "type": "string", "minLength": 1 },
    "parent_narrative": { "type": "string", "minLength": 1 },
    "scenario_type": { "enum": ["success", "failure", "s7b", "s7c", "parent_branch_separation", "long_no_change"] },
    "requested_stage": { "type": "string", "minLength": 1 },
    "data_confidence": { "type": "number", "minimum": 0, "maximum": 100 },
    "branch_id": { "type": ["string", "null"] },
    "slices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slice_id", "as_of"],
        "properties": {
          "slice_id": { "type": "string", "minLength": 1 },
          "as_of": { "type": "string", "format": "date" }
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "evidence_id",
          "topic_id",
          "event_date",
          "available_at",
          "event_title",
          "source_name",
          "evidence_strength",
          "affected_layer",
          "stage_effect",
          "parent_or_branch",
          "confidence"
        ],
        "properties": {
          "evidence_id": { "type": "string", "minLength": 1 },
          "topic_id": { "type": "string", "minLength": 1 },
          "event_date": { "type": "string", "format": "date" },
          "available_at": { "type": "string", "format": "date" },
          "event_title": { "type": "string", "minLength": 1 },
          "source_name": { "type": "string", "minLength": 1 },
          "evidence_strength": { "enum": ["E0", "E1", "E2", "E3", "E4"] },
          "affected_layer": {
            "type": "array",
            "minItems": 1,
            "items": { "enum": ["perception", "capital", "pricing", "reality", "feedback", "friction"] }
          },
          "stage_effect": { "type": "string", "minLength": 1 },
          "parent_or_branch": { "enum": ["parent", "branch", "asset", "unknown"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 100 }
        }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revealed_at", "status", "correct_stage", "summary", "outcome_evidence_ids"],
      "properties": {
        "revealed_at": { "type": "string", "format": "date" },
        "status": { "enum": ["confirmed", "weakened", "falsified", "no_change"] },
        "correct_stage": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "outcome_evidence_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "calibration_note": { "type": "string", "minLength": 1 }
  }
}
