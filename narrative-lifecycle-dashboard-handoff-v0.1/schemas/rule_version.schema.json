{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "RuleVersion",
  "required": [
    "rule_version_id",
    "name",
    "version"
  ],
  "properties": {
    "rule_version_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "effective_date": {
      "type": "string",
      "format": "date"
    },
    "summary": {
      "type": "string"
    },
    "changed_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "schema_version": {
      "type": "string"
    }
  }
}
