{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "RawSource",
  "required": [
    "raw_source_id",
    "source_name"
  ],
  "properties": {
    "raw_source_id": {
      "type": "string"
    },
    "source_name": {
      "type": "string"
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "source_type": {
      "type": "string"
    },
    "raw_text": {
      "type": "string"
    },
    "fetched_at": {
      "type": "string",
      "format": "date-time"
    },
    "content_hash": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    }
  }
}
