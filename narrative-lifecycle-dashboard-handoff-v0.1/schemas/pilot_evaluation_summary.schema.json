{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "title": "PilotEvaluationSummary",
  "additionalProperties": false,
  "required": [
    "research_time_saved",
    "operator_agreement_rate",
    "stage_change_precision",
    "early_radar_follow_through",
    "false_positive_count",
    "missed_change_count",
    "falsification_count",
    "consecutive_no_change_runs"
  ],
  "properties": {
    "research_time_saved": { "$ref": "#/$defs/metric" },
    "operator_agreement_rate": { "$ref": "#/$defs/metric" },
    "stage_change_precision": { "$ref": "#/$defs/metric" },
    "early_radar_follow_through": { "$ref": "#/$defs/metric" },
    "false_positive_count": { "$ref": "#/$defs/metric" },
    "missed_change_count": { "$ref": "#/$defs/metric" },
    "falsification_count": { "$ref": "#/$defs/metric" },
    "consecutive_no_change_runs": { "$ref": "#/$defs/metric" }
  },
  "$defs": {
    "metric": {
      "oneOf": [
        { "type": "number" },
        { "const": "insufficient_history" }
      ]
    }
  }
}
