{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "title": "EvidenceImportDraftList",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": true,
    "required": [
      "evidence_id",
      "topic_id",
      "scope",
      "event_date",
      "available_at",
      "event_title",
      "event_summary",
      "event_type",
      "source_name",
      "source_type",
      "evidence_strength",
      "affected_layer",
      "stage_effect",
      "polarity",
      "interpretation",
      "limitation",
      "confidence"
    ],
    "properties": {
      "evidence_id": {
        "type": "string",
        "minLength": 1
      },
      "topic_id": {
        "type": "string",
        "minLength": 1
      },
      "branch_id": {
        "type": [
          "string",
          "null"
        ]
      },
      "scope": {
        "type": "string",
        "enum": [
          "parent",
          "branch"
        ]
      },
      "event_date": {
        "type": "string",
        "format": "date"
      },
      "available_at": {
        "type": "string",
        "format": "date"
      },
      "event_title": {
        "type": "string",
        "minLength": 1
      },
      "event_summary": {
        "type": "string",
        "minLength": 1
      },
      "event_type": {
        "type": "string",
        "minLength": 1
      },
      "source_name": {
        "type": "string",
        "minLength": 1
      },
      "source_url": {
        "type": [
          "string",
          "null"
        ],
        "format": "uri"
      },
      "source_type": {
        "type": "string",
        "enum": [
          "official",
          "filing",
          "news",
          "research",
          "academic",
          "company",
          "other"
        ]
      },
      "evidence_strength": {
        "type": "string",
        "enum": [
          "E0",
          "E1",
          "E2",
          "E3",
          "E4"
        ]
      },
      "affected_layer": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "enum": [
            "name",
            "capital",
            "pricing",
            "reality",
            "momentum",
            "friction",
            "data_confidence"
          ]
        }
      },
      "stage_effect": {
        "type": "string",
        "enum": [
          "upgrade",
          "maintain",
          "downgrade",
          "watch_upgrade",
          "split_branch",
          "no_change"
        ]
      },
      "polarity": {
        "type": "string",
        "enum": [
          "positive",
          "negative",
          "mixed",
          "neutral"
        ]
      },
      "interpretation": {
        "type": "string",
        "minLength": 1
      },
      "limitation": {
        "type": "string",
        "minLength": 1
      },
      "confidence": {
        "type": "string",
        "enum": [
          "low",
          "medium",
          "high"
        ]
      }
    },
    "allOf": [
      {
        "if": {
          "properties": {
            "scope": {
              "const": "branch"
            }
          },
          "required": [
            "scope"
          ]
        },
        "then": {
          "required": [
            "branch_id"
          ]
        }
      }
    ]
  }
}
